{
  "consumer": { "name": "Veritasor-Frontend" },
  "provider": { "name": "Veritasor-Backend" },
  "interactions": [
    {
      "description": "a request for the health check",
      "providerState": "server is healthy",
      "request": {
        "method": "GET",
        "path": "/api/health"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "body": {
          "status": "ok",
          "service": "veritasor-backend"
        },
        "matchingRules": {
          "$.body.status": { "match": "type" },
          "$.body.service": { "match": "type" },
          "$.body.timestamp": { "match": "type" }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "2.0.0"
    }
  }
}
