    "/api/health": {
      "get": {
        "description": "Liveness and readiness probe. Use ?mode=deep for full dependency check.",
        "parameters": [
          {
            "description": "shallow (default) or deep dependency check",
            "in": "query",
            "name": "mode",
            "required": false,
            "schema": {
              "enum": [
                "shallow",
                "deep"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "db": {
                      "enum": [
                        "ok",
                        "down"
                      ],
                      "type": "string"
                    },
                    "email": {
                      "enum": [
                        "ok",
                        "down"
                      ],
                      "type": "string"
                    },
                    "mode": {
                      "enum": [
                        "shallow",
                        "deep"
                      ],
                      "type": "string"
                    },
                    "redis": {
                      "enum": [
                        "ok",
                        "down"
                      ],
                      "type": "string"
                    },
                    "service": {
                      "example": "veritasor-backend",
                      "type": "string"
                    },
                    "soroban": {
                      "enum": [
                        "ok",
                        "down"
                      ],
                      "type": "string"
                    },
                    "status": {
                      "enum": [
                        "ok",
                        "degraded",
                        "unhealthy"
                      ],
                      "type": "string"
                    },
                    "timestamp": {
                      "format": "date-time",
                      "type": "string"
                    }
                  },
                  "required": [
                    "service",
                    "status",
                    "timestamp"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service healthy or degraded"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Service unhealthy (deep mode only)"
          }
        },
        "summary": "Health check",
        "tags": [
          "health"
        ]
      }
    },
